APP_ENV=production
NEXT_PUBLIC_APP_ENV=production

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=lgus-sjc-scholarship.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=lgus-sjc-scholarship
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=lgus-sjc-scholarship.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=69562690564
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Use (default) for the primary Firestore database, or a named database id such as staging.
FIRESTORE_DATABASE_ID=(default)
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=(default)

# Firebase Admin SDK credentials for non-Google managed Node.js hosts.
# Recommended for Hostinger: import this as one single-line environment variable.
# Generate from the downloaded service-account JSON:
# node -e "console.log(Buffer.from(require('fs').readFileSync('secrets/firebase-service-account.json')).toString('base64'))"
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# Alternative env-var format if your host handles long multiline secrets well.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Local file fallback. Keep the JSON under secrets/ or outside the repo.
FIREBASE_SERVICE_ACCOUNT_PATH=secrets/firebase-service-account.json
